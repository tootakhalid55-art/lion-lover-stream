# Nova TV — environment template.
# Never commit real values. Managed secrets live in the Lovable Cloud
# secret store (dev/prod) or the Docker/Terraform secret manager.

# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Supabase (server) ────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Supabase (client / build) ────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ── Session / crypto ─────────────────────────────────────────────────
SESSION_SECRET=

# ── AI Gateway ───────────────────────────────────────────────────────
LOVABLE_API_KEY=

# ── Xtream upstream ──────────────────────────────────────────────────
XTREAM_SERVER_URL=
XTREAM_DEFAULT_USERNAME=
XTREAM_DEFAULT_PASSWORD=

# ── Bootstrap ────────────────────────────────────────────────────────
NOVA_ADMIN_BOOTSTRAP_CODE=

# ── Ops / Feature toggles ────────────────────────────────────────────
MAINTENANCE=0
